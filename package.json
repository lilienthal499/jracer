{
  "name": "jracer",
  "version": "4.0.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs');const c=JSON.parse(fs.readFileSync('public/backend/config.json'));c.players=c.players.map(p=>{if(p.recordingFile){const r=JSON.parse(fs.readFileSync('public/backend/'+p.recordingFile));return{...p,recording:r,recordingFile:undefined}}return p});fs.writeFileSync('public/backend/config-with-recordings.json',JSON.stringify(c))\"",
    "dev": "npm run prebuild && npx partykit dev",
    "deploy": "npm run prebuild && npx partykit deploy"
  },
  "dependencies": {
    "partykit": "^0.0.115"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "eslint": "^8.57.0",
    "happy-dom": "^20.8.4",
    "http-server": "^14.1.1",
    "jsdom": "^29.0.1",
    "live-server": "^1.2.0",
    "prettier": "^3.2.5",
    "vitest": "^4.1.0"
  }
}
